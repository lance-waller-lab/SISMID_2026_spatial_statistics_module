-450,600 ),
xlim=c(0,5000),cex.axis=1.5,cex.lab=1.5 )
lines(dists,Lhat.con-dists,lwd=2)
lines(dists,Lenv.con.up - dists,lty=2)
lines(dists,Lenv.con.lo - dists,lty=2)
lines(dists,Lenv.con.975 - dists,lty=1)
